pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract Mono is ERC20, Ownable {

    uint256 public constant MAX_SUPPLY =
        100_000_000 * 10 ** 18;

    uint256 public transactionFee = 1;

    address public treasuryWallet;

    mapping(address => bool) public feeExempt;

    event TreasuryWalletChanged(address indexed wallet);
    event TransactionFeeUpdated(uint256 fee);
    event TokensMinted(address indexed to, uint256 amount);
    event TokensBurned(address indexed from, uint256 amount);

    constructor(address _treasuryWallet)
        ERC20("Mono", "MONO")
        Ownable(msg.sender)
    {
        treasuryWallet = _treasuryWallet;

        _mint(
            msg.sender,
            10_000_000 * 10 ** decimals()
        );

        feeExempt[msg.sender] = true;
        feeExempt[address(this)] = true;
    }

    function setTreasuryWallet(address wallet)
        external
        onlyOwner
    {
        treasuryWallet = wallet;

        emit TreasuryWalletChanged(wallet);
    }

    function setTransactionFee(uint256 fee)
        external
        onlyOwner
    {
        require(fee <= 5, "Fee too high");

        transactionFee = fee;

        emit TransactionFeeUpdated(fee);
    }

    function setFeeExempt(
        address account,
        bool exempt
    )
        external
        onlyOwner
    {
        feeExempt[account] = exempt;
    }

    function mint(address to, uint256 amount)
        external
        onlyOwner
    {
        require(
            totalSupply() + amount <= MAX_SUPPLY,
            "Max supply exceeded"
        );

        _mint(to, amount);

        emit TokensMinted(to, amount);
    }

    function burn(uint256 amount) external {

        _burn(msg.sender, amount);

        emit TokensBurned(msg.sender, amount);
    }

    function _update(
        address from,
        address to,
        uint256 amount
    )
        internal
        override
    {
        if (
            !feeExempt[from] &&
            !feeExempt[to] &&
            from != address(0) &&
            to != address(0)
        ) {

            uint256 feeAmount =
                (amount * transactionFee) / 100;

            uint256 sendAmount =
                amount - feeAmount;

            super._update(
                from,
                treasuryWallet,
                feeAmount
            );

            super._update(
                from,
                to,
                sendAmount
            );

        } else {

            super._update(from, to, amount);
        }
    }

    function circulatingSupply()
        external
        view
        returns (uint256)
    {
        return totalSupply();
    }
}
